# HOSCORE Server — Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL Database (Neon)
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require"

# Server
PORT=5000
NODE_ENV=production

# JWT Auth — CHANGE THIS IN PRODUCTION
JWT_SECRET=your-secure-random-secret-here

# CORS — frontend URL
CLIENT_URL=http://localhost:5173

# SEO & Public Metadata
PUBLIC_APP_URL=http://localhost:5173

# Cloudflare R2 (for file uploads)
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=hoscore-uploads
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://your-bucket-public-url.r2.dev

# Outbound Email (Resend) - Optional
# RESEND_API_KEY=re_your_api_key
# FROM_EMAIL=noreply@yourdomain.com

# Payment Gateway (Razorpay) — required for production billing
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# SMS/Email Gateway (MSG91) - Optional
# MSG91_AUTHKEY=your_msg91_authkey
# MSG91_TEMPLATE_ID=hoscore_otp
# MSG91_EMAIL_DOMAIN=yourdomain.com
# MSG91_FROM_EMAIL=noreply@yourdomain.com
# MSG91_FROM_NAME=HOSCORE

