// HOSCORE — Multi-Tenant Hospital Network Platform
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============== PLATFORM AUTH MODELS ==============

// Unified user account — one email, one password, many dashboards
model User {
  id            String       @id @default(uuid())
  email         String       @unique
  password      String
  name          String
  phone         String?      @unique
  avatar        String?
  isSuperAdmin  Boolean      @default(false)
  isVerified    Boolean      @default(false)
  otpCode       String?      // stores SHA256(otp + OTP_SECRET), never the plaintext OTP
  otpExpiresAt  DateTime?
  otpAttempts   Int          @default(0)  // failed verify attempts for the current OTP
  otpLastSentAt DateTime?                  // last time an OTP was issued (resend cooldown)
  memberships   Membership[]
  patientProfile Patient?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// Links a User to a Hospital with a specific role
model Membership {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospitalId  String
  hospital    Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  staffTypeId String?
  staffType   StaffType? @relation(fields: [staffTypeId], references: [id], onDelete: SetNull)
  role        String   // ADMIN, DOCTOR, NURSE, RECEPTIONIST, PHARMACIST, LAB_TECH, STAFF, CLEANER
  department  String   @default("General")
  permissions Json?
  status      String   @default("ACTIVE") // ACTIVE, SUSPENDED, INVITED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, hospitalId, role])
}

model StaffType {
  id          String       @id @default(uuid())
  hospitalId  String?
  hospital    Hospital?    @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  name        String
  code        String
  description String?
  role        String       @default("STAFF")
  permissions Json
  isPreset    Boolean      @default(false)
  isActive    Boolean      @default(true)
  memberships Membership[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([hospitalId, code])
}

// ============== HOSPITAL & SUBSCRIPTION ==============

model Hospital {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  address       String?
  country       String?
  city          String?
  state         String?
  contact       String?
  email         String?
  description   String?
  logo          String?
  photos        Json?
  rating        Float          @default(0)
  isPartnered   Boolean        @default(false)
  isActive      Boolean        @default(true)
  memberships   Membership[]
  subscriptions Subscription[]
  rooms         Room[]
  appointments  Appointment[]
  doctors       Doctor[]
  staff         Staff[]
  patients      Patient[]
  opdQueues     OPDQueue[]
  labOrders     LabOrder[]
  vitalRecords  VitalRecord[]
  dischargeSummaries DischargeSummary[]
  prescriptions Prescription[]
  shiftSchedules ShiftSchedule[]
  feedbacks     Feedback[]
  insuranceClaims InsuranceClaim[]
  expenses      Expense[]
  inventories   Inventory[]
  schedules     Schedule[]
  defaultSchedules DefaultSchedule[]
  notices       Notice[]
  leaveRequests LeaveRequest[]
  staffGroups   StaffGroup[]
  staffTypes    StaffType[]
  auditLogs     AuditLog[]
  billings      Billing[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Subscription {
  id                     String   @id @default(uuid())
  hospitalId             String
  hospital               Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  plan                   String   @default("STARTER") // STARTER, PROFESSIONAL, ENTERPRISE
  pricePerUser           Float    @default(150)       // ₹150/user/year
  maxUsers               Int      @default(50)        // plan tier cap
  billedSeats            Int      @default(0)         // seats paid for
  status                 String   @default("TRIAL")   // TRIAL, ACTIVE, EXPIRED, CANCELLED
  autopayEnabled         Boolean  @default(false)
  razorpaySubscriptionId String?  @unique
  razorpayPlanId         String?
  trialEndsAt            DateTime?
  startDate              DateTime @default(now())
  endDate                DateTime
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Payment {
  id                     String    @id @default(uuid())
  hospitalId             String
  orderId                String    @unique
  paymentId              String?
  signature              String?
  amount                 Float
  currency               String    @default("INR")
  plan                   String
  userCount              Int       @default(1)
  paymentType            String    @default("ONE_TIME") // ONE_TIME, SUBSCRIPTION, RENEWAL
  razorpaySubscriptionId String?
  status                 String    @default("CREATED") // CREATED, PAID, FAILED
  paidAt                 DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

// ============== CLINICAL CORE MODELS ==============

model Appointment {
  id          String   @id @default(uuid())
  hospitalId  String
  hospital    Hospital @relation(fields: [hospitalId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctorId    String?
  doctor      Doctor?  @relation(fields: [doctorId], references: [id])
  time        String
  date        DateTime
  tokenNumber Int
  status      String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  isRepeat    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Room {
  id         String   @id @default(uuid())
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])
  name       String
  type       String
  capacity   Int
  basePrice  Float    @default(50)
  beds       Bed[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Bed {
  id           String      @id @default(uuid())
  roomId       String
  room         Room        @relation(fields: [roomId], references: [id])
  bedNumber    String
  status       String      @default("AVAILABLE")
  pricePerDay  Float
  admissions   Admission[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Patient {
  id                           String        @id @default(uuid())
  userId                       String?       @unique
  user                         User?         @relation(fields: [userId], references: [id])
  hospitalId                   String?
  hospital                     Hospital?     @relation(fields: [hospitalId], references: [id])
  name                         String
  contact                      String?
  email                        String?
  dateOfBirth                  DateTime?
  gender                       String?
  bloodGroup                   String?       @default("O+")
  status                       String        @default("Out-Patient")
  medicalHistory               String?
  sixDigitId                   String?       @unique
  isHoscoreUser                Boolean       @default(true)
  registrationMode             String        @default("HOSCORE") // HOSCORE, WALK_IN_MANUAL
  manualCareNote               String?
  nextAppointmentAlertDate     DateTime?
  nextAppointmentAlertInterval String?
  nextAppointmentAlertStatus   String?       @default("ACTIVE")
  admissions                   Admission[]
  prescriptions                Prescription[]
  appointments                 Appointment[]
  parentId                     String?
  parent                       Patient?      @relation("PatientToDependents", fields: [parentId], references: [id], onDelete: SetNull)
  dependents                   Patient[]     @relation("PatientToDependents")
  accessGrants                 PatientAccessGrant[]
  vaccinations                 Vaccination[]
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt
}

model Admission {
  id            String    @id @default(uuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  bedId         String
  bed           Bed       @relation(fields: [bedId], references: [id])
  admissionDate DateTime  @default(now())
  dischargeDate DateTime?
  reason        String?
  status        String    @default("Active")
  billing       Billing?
  reports       Report[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Doctor {
  id            String         @id @default(uuid())
  hospitalId    String?
  hospital      Hospital?      @relation(fields: [hospitalId], references: [id])
  name          String
  specialty     String
  contact       String?
  email         String?
  status        String         @default("On Duty")
  rating        Float          @default(4.5)
  patientsCount Int            @default(0)
  prescriptions Prescription[]
  appointments  Appointment[]
  accessGrants  PatientAccessGrant[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Staff {
  id         String   @id @default(uuid())
  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])
  name       String
  role       String
  department String   @default("General")
  shift      String   @default("Morning")
  status     String   @default("On Duty")
  contact    String?
  email      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Billing {
  id            String    @id @default(uuid())
  hospitalId    String?
  hospital      Hospital? @relation(fields: [hospitalId], references: [id])
  admissionId   String    @unique
  admission     Admission @relation(fields: [admissionId], references: [id])
  roomCharges   Float     @default(0)
  doctorFees    Float     @default(0)
  pharmacyFees  Float     @default(0)
  labFees       Float     @default(0)
  totalAmount   Float     @default(0)
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Inventory {
  id           String   @id @default(uuid())
  hospitalId   String?
  hospital     Hospital? @relation(fields: [hospitalId], references: [id])
  itemName     String
  type         String
  stock        Int      @default(0)
  reorderLevel Int      @default(10)
  unit         String   @default("units")
  supplier     String?
  price        Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Prescription {
  id           String   @id @default(uuid())
  hospitalId   String?
  hospital     Hospital? @relation(fields: [hospitalId], references: [id])
  doctorId     String
  doctor       Doctor   @relation(fields: [doctorId], references: [id])
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  diagnosis    String   @default("General")
  medicines    String
  instructions String?
  status       String   @default("ISSUED")
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Report {
  id          String    @id @default(uuid())
  admissionId String
  admission   Admission @relation(fields: [admissionId], references: [id])
  vitals      String?
  notes       String?
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============== MANAGEMENT MODELS ==============

model Schedule {
  id         String   @id @default(uuid())
  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])
  date       DateTime
  isOpen     Boolean  @default(true)
  openTime   String   @default("08:00")
  closeTime  String   @default("20:00")
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DefaultSchedule {
  id         String   @id @default(uuid())
  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])
  dayOfWeek  Int
  isOpen     Boolean  @default(true)
  openTime   String   @default("08:00")
  closeTime  String   @default("20:00")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notice {
  id          String    @id @default(uuid())
  hospitalId  String?
  hospital    Hospital? @relation(fields: [hospitalId], references: [id])
  title       String
  body        String
  priority    String    @default("INFO")
  isPinned    Boolean   @default(false)
  expiresAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LeaveRequest {
  id         String    @id @default(uuid())
  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])
  staffId    String?
  doctorId   String?
  staffName  String
  role       String
  startDate  DateTime
  endDate    DateTime
  type       String    @default("CASUAL")
  reason     String?
  status     String    @default("PENDING")
  reviewedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model StaffGroup {
  id          String        @id @default(uuid())
  hospitalId  String?
  hospital    Hospital?     @relation(fields: [hospitalId], references: [id])
  name        String
  description String?
  color       String        @default("#3b82f6")
  members     GroupMember[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GroupMember {
  id         String     @id @default(uuid())
  groupId    String
  group      StaffGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  staffId    String?
  doctorId   String?
  memberName String
  role       String
  createdAt  DateTime   @default(now())
}

// ============== CLINICAL WORKFLOW MODELS ==============

model OPDQueue {
  id            String    @id @default(uuid())
  hospitalId    String?
  hospital      Hospital? @relation(fields: [hospitalId], references: [id])
  patientName   String
  patientId     String?
  doctorName    String
  doctorId      String?
  tokenNumber   Int
  department    String    @default("General")
  status        String    @default("WAITING")
  estimatedWait Int       @default(15)
  notes         String?
  date          DateTime  @default(now())
  calledAt      DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model LabOrder {
  id           String    @id @default(uuid())
  hospitalId   String?
  hospital     Hospital? @relation(fields: [hospitalId], references: [id])
  patientName  String
  patientId    String?
  doctorName   String
  doctorId     String?
  testName     String
  testType     String    @default("Blood Test")
  priority     String    @default("ROUTINE")
  status       String    @default("ORDERED")
  result       String?
  normalRange  String?
  unit         String?
  remarks      String?
  orderedAt    DateTime  @default(now())
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model VitalRecord {
  id               String    @id @default(uuid())
  hospitalId       String?
  hospital         Hospital? @relation(fields: [hospitalId], references: [id])
  patientName      String
  patientId        String?
  recordedBy       String?
  bloodPressure    String?
  heartRate        Int?
  temperature      Float?
  oxygenSaturation Int?
  respiratoryRate  Int?
  weight           Float?
  bloodSugar       Float?
  notes            String?
  recordedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
}

model DischargeSummary {
  id               String    @id @default(uuid())
  hospitalId       String?
  hospital         Hospital? @relation(fields: [hospitalId], references: [id])
  patientName      String
  patientId        String?
  admissionId      String?
  admissionDate    DateTime?
  dischargeDate    DateTime  @default(now())
  diagnosis        String
  treatmentGiven   String?
  surgeryPerformed String?
  medications      String?
  followUpDate     DateTime?
  followUpNotes    String?
  doctorName       String
  status           String    @default("DRAFT")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ============== OPERATIONS MODELS ==============

model AuditLog {
  id         String    @id @default(uuid())
  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])
  userId     String?
  userName   String
  userRole   String?
  action     String
  entity     String
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime  @default(now())
}

model ShiftSchedule {
  id         String    @id @default(uuid())
  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])
  staffName  String
  staffId    String?
  role       String
  department String    @default("General")
  shiftType  String    @default("MORNING")
  date       DateTime
  startTime  String    @default("08:00")
  endTime    String    @default("16:00")
  status     String    @default("SCHEDULED")
  swapRequested Boolean @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Feedback {
  id           String    @id @default(uuid())
  hospitalId   String?
  hospital     Hospital? @relation(fields: [hospitalId], references: [id])
  patientName  String
  patientId    String?
  doctorName   String?
  department   String?
  rating       Int       @default(5)
  category     String    @default("GENERAL")
  comment      String?
  isAnonymous  Boolean   @default(false)
  createdAt    DateTime  @default(now())
}

model InsuranceClaim {
  id               String    @id @default(uuid())
  hospitalId       String?
  hospital         Hospital? @relation(fields: [hospitalId], references: [id])
  patientName      String
  patientId        String?
  policyNumber     String
  insuranceCompany String
  claimAmount      Float
  approvedAmount   Float?
  status           String    @default("SUBMITTED")
  admissionId      String?
  diagnosis        String?
  documents        String?
  submittedAt      DateTime  @default(now())
  reviewedAt       DateTime?
  remarks          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  hospitalId  String?
  hospital    Hospital? @relation(fields: [hospitalId], references: [id])
  title       String
  category    String   @default("GENERAL")
  amount      Float
  vendor      String?
  paidBy      String?
  paidDate    DateTime @default(now())
  receipt     String?
  notes       String?
  status      String   @default("PAID")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PatientAccessGrant {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  status      String   @default("ACTIVE") // ACTIVE, REVOKED
  grantedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([patientId, doctorId])
}

model Vaccination {
  id          String    @id @default(uuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name        String    // e.g. "BCG", "Hepatitis B", "Polio", "DPT", "MMR"
  scheduledAge String    // e.g. "At Birth", "6 Weeks", "9 Months"
  status      String    @default("PENDING") // PENDING, COMPLETED
  givenAt     DateTime?
  givenBy     String?   // Doctor or clinic name
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
